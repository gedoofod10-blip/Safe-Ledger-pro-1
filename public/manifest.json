    "action": "/share",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "files": [
        {
          "name": "file",
          "accept": ["application/json", "application/pdf", "text/plain", "image/*"]
        }
      ]
    }
  },
  "shortcuts": [
    {
      "name": "إضافة عميل جديد",
      "short_name": "عميل جديد",
      "description": "إضافة عميل جديد إلى دفتر الحسابات",
      "url": "/clients",
      "icons": [
        {
          "src": "/pwa-192x192.png",
          "sizes": "192x192",
          "type": "image/png"
        }
      ]
    },
    {
      "name": "إضافة معاملة",
      "short_name": "معاملة جديدة",
      "description": "تسجيل معاملة مالية جديدة",
      "url": "/add-transaction",
      "icons": [
        {
          "src": "/pwa-192x192.png",
          "sizes": "192x192",
          "type": "image/png"
        }
      ]
    },
    {
      "name": "التقارير",
      "short_name": "التقارير",
      "description": "عرض التقارير المالية",
      "url": "/reports",
      "icons": [
        {
          "src": "/pwa-192x192.png",
          "sizes": "192x192",
          "type": "image/png"
        }
      ]
    }
  ],
  "protocol_handlers": [
    {
      "protocol": "web+ledger",
      "url": "/import?data=%s"
    }
  ],
  "file_handlers": [
    {
      "action": "/import",
      "accept": {
        "application/json": [".json"],
        "text/plain": [".txt", ".bak"]
      }
    }
  ],
  "prefer_related_applications": false,
  "related_applications": []
